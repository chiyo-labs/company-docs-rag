{
  "name": "company-docs-rag",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "ingest": "tsx --env-file .env.local src/ingest/ingestText.ts",
    "ingest:pdf": "tsx --env-file .env.local src/ingest/ingestPdf.ts",
    "test:chunker": "tsx scripts/testChunker.ts",
    "test:search": "tsx --env-file .env.local scripts/testSearch.ts",
    "test:answer": "tsx --env-file .env.local scripts/testAnswer.ts",
    "eval": "tsx --env-file .env.local scripts/evaluateRag.ts",
    "eval:yes": "tsx --env-file .env.local scripts/evaluateRag.ts --yes"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.0.0",
    "next": "^15.0.0",
    "openai": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
