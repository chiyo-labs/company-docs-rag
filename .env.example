# ==============================================================
# .env.example — 実際の値は .env.local に記入してください
# .env.local は Git 管理対象外です (.gitignore 参照)
# ==============================================================

# Supabase
# Supabase Dashboard > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # サーバーサイドのみ使用

# OpenAI (Embedding生成に使用: text-embedding-3-small)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (回答生成に使用: Claude)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# 認証 - 許可するメールドメイン（例: example.com）
# 未設定の場合はドメイン制限なし
ALLOWED_EMAIL_DOMAIN=
